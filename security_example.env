# Copie para security.env no host ou no runner de deploy.

#### Ambiente
# GID do grupo docker no host.
GID_DOCKER=
# Ambiente de execucao: dev, homol ou prod.
ENVIRONMENT=

#### Banco de dados da aplicacao SEI IA
# Usuario do banco PostgreSQL interno.
DB_SEIIA_USER=
# Senha do banco PostgreSQL interno.
DB_SEIIA_PWD=

#### Solr
# Usuario do Solr.
SOLR_USER=
# Senha do Solr.
SOLR_PASSWORD=

#### Airflow
# Nome do banco de metadados do Airflow.
AIRFLOW_POSTGRES_DB=
# Usuario do PostgreSQL do Airflow.
AIRFLOW_POSTGRES_USER=
# Usuario do RabbitMQ do Airflow.
AIRFLOW_AMQP_USER=
# Usuario da interface web do Airflow.
_AIRFLOW_WWW_USER_USERNAME=
# Senha da interface web do Airflow.
_AIRFLOW_WWW_USER_PASSWORD=
# Senha do PostgreSQL do Airflow.
AIRFLOW_POSTGRES_PASSWORD=
# Senha do RabbitMQ do Airflow.
AIRFLOW_AMQP_PASSWORD=
# Chave secreta da sessao do Airflow Webserver.
AIRFLOW__WEBSERVER__SECRET_KEY=

#### LiteLLM Proxy
# Versao da API OpenAI/Azure usada pelo proxy.
OPENAI_API_VERSION=
# API key do proxy LiteLLM, se habilitada.
ASSISTENTE_LITELLM_PROXY_API_KEY=
# Aliases dos modelos no LiteLLM Proxy (devem coincidir com model_name no litellm_config).
ASSISTENTE_LITELLM_STANDARD_MODEL_NAME=
ASSISTENTE_LITELLM_MINI_MODEL_NAME=
ASSISTENTE_LITELLM_NANO_MODEL_NAME=
ASSISTENTE_LITELLM_THINK_MODEL_NAME=
ASSISTENTE_LITELLM_EMBEDDING_MODEL_NAME=
ASSISTENTE_LITELLM_STT_MODEL_NAME=
ASSISTENTE_OCR_MODEL=
# Modelos no litellm_config (deve incluir prefixo do provedor).
# Conexao direta com Azure:  azure/gpt-5.4
# Via LiteLLM proxy central: openai/seiia-ds
LITELLM_STANDARD_MODEL=
LITELLM_MINI_MODEL=
LITELLM_NANO_MODEL=
# Limite de tokens de saida para modelos think (varia por ambiente, ex: 32768 em dev, 102400 em prod).
LITELLM_THINK_MAX_TOKENS=

#### Integracao com a API do SEI
# Identificador do servico na API do SEI.
SEI_API_DB_IDENTIFIER_SERVICE=
# Endereco base da API de integracao com os dados do SEI.
SEI_ADDRESS=

#### Azure AI e Bing Ground Search
# Endpoint do projeto Azure AI usado pelo Ground Search.
PROJECT_ENDPOINT=
# Tenant ID do Azure AD.
AZURE_TENANT_ID=
# Identificador do agente web no Azure AI.
AZURE_WEB_AGENT_ID=
# Client secret do app registrado no Azure.
AZURE_CLIENT_SECRET=
# Client ID do app registrado no Azure.
AZURE_CLIENT_ID=
# Nome da conexao Bing Grounding / Ground Search no Azure AI.
BING_CONNECTION_NAME=
# Nome do deployment do modelo usado no Azure AI.
MODEL_DEPLOYMENT_NAME=

#### Langfuse (opcional, usado em ambiente de desenvolvimento)
# URL do Langfuse para observabilidade local/dev.
LANGFUSE_URL=
# Public key do Langfuse.
LANGFUSE_PUBLIC_KEY=
# Secret key do Langfuse.
LANGFUSE_SECRET_KEY=
# Salt interno do Langfuse.
LANGFUSE_SECRET_SALT=
# Secret do NextAuth usado pelo Langfuse.
LANGFUSE_NEXTAUTH_SECRET=
