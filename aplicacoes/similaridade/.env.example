# Variáveis de ambiente - sei-similaridade API
# Copie este arquivo para .env e configure os valores

# Timezone
TZ=America/Sao_Paulo

# Log Level [critical|error|warning|info|debug|trace]
LOG_LEVEL=DEBUG

# === SOLR ===
SOLR_ADDRESS=http://localhost:8983/solr
SOLR_MLT_PROCESS_CORE=processos_mlt
SOLR_MLT_JURISPRUDENCE_CORE=documentos_bm25
SOLR_USER=
SOLR_PASSWORD=

# === PostgreSQL (sei-similaridade) ===
DB_SEIIA_USER=postgres
DB_SEIIA_PWD=password
DB_SEIIA_HOST=localhost
DB_SEIIA_SIMILARIDADE=sei_similaridade

# === Banco de dados SEI (Oracle) ===
DB_SEI_ORACLE_SID=
SEI_API_DB_ADDRESS=
SEI_API_DB_USER=Usuario_IA
SEI_API_DB_PASSWORD=
SEI_API_DB_TIMEOUT=120
SEI_API_DB_CHUNK_SIZE=100
SEI_API_DB_IDENTIFIER_SERVICE=

# === Jobs API ===
JOBS_API_ADDRESS=https://jobs_api:8642

# === Autenticação (opcional) ===
USE_AUTHENTICATION=false
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === OpenTelemetry (opcional) ===
ENABLE_OTEL_METRICS=false

# === SSL ===
VERIFY_SSL=false

# === Armazenamento ===
STORAGE_PROJ_DIR=/opt/sei_similaridade/

# === Configurações adicionais ===
CONFIG_AUTO_TESTS_PATH=
STOPWORDS=
