# =============================================================================
# SEI-IA Assistente - Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores adequados
# =============================================================================

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES GERAIS
# -----------------------------------------------------------------------------
TZ=America/Sao_Paulo
LOG_LEVEL=INFO                          # critical|error|warning|info|debug|trace

# -----------------------------------------------------------------------------
# BANCO DE DADOS POSTGRESQL (PGVECTOR)
# -----------------------------------------------------------------------------
DB_SEIIA_HOST=pgvector_assistente
DB_SEIIA_PORT=5432
DB_SEIIA_USER=
DB_SEIIA_PWD=
DB_SEIIA_ASSISTENTE=SEI_LLM
DB_SEIIA_ASSISTENTE_SCHEMA=sei_llm


# -----------------------------------------------------------------------------
# API SEI (Acesso ao banco de dados do SEI)
# -----------------------------------------------------------------------------
SEI_API_DB_ADDRESS=
SEI_API_DB_IDENTIFIER_SERVICE=
SEI_API_DB_USER=Usuario_IA
SEI_API_DB_TIMEOUT=120

# -----------------------------------------------------------------------------
# REDIS CACHE
# -----------------------------------------------------------------------------
ASSISTENTE_REDIS_URI=redis://redis_cache:6379/0
ASSISTENTE_CACHE_ENABLED=true
ASSISTENTE_CACHE_TTL_SECONDS=120

# -----------------------------------------------------------------------------
# LANGFUSE (Observabilidade)
# -----------------------------------------------------------------------------
LANGFUSE_URL=http://langfuse_assistente:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
ASSISTENTE_USE_LANGFUSE=true

# -----------------------------------------------------------------------------
# LITELLM PROXY (Conexao com modelos LLM)
# -----------------------------------------------------------------------------
# O LiteLLM Proxy gerencia toda a comunicacao com Azure OpenAI/outros providers.
# Configurar o proxy separadamente com as credenciais dos modelos.
ASSISTENTE_LITELLM_PROXY_URL=http://localhost:4000
# ASSISTENTE_LITELLM_PROXY_API_KEY=         # Opcional - API key para autenticacao no proxy

# Aliases dos modelos no LiteLLM Proxy (devem coincidir com model_name no litellm_config)
ASSISTENTE_LITELLM_STANDARD_MODEL_NAME=standard
ASSISTENTE_LITELLM_MINI_MODEL_NAME=mini
ASSISTENTE_LITELLM_NANO_MODEL_NAME=nano
ASSISTENTE_LITELLM_THINK_MODEL_NAME=think
ASSISTENTE_LITELLM_EMBEDDING_MODEL_NAME=embedding
ASSISTENTE_LITELLM_STT_MODEL_NAME=speech-to-text

# Nomes reais dos modelos (base_model no litellm_config, preenchidos pelo CI/CD via Gitlab)
LITELLM_STANDARD_MODEL=
LITELLM_MINI_MODEL=
LITELLM_NANO_MODEL=

# -----------------------------------------------------------------------------
# MODELO DE EMBEDDINGS (via LiteLLM Proxy)
# -----------------------------------------------------------------------------
ASSISTENTE_EMBEDDING_MODEL=text-embedding-3-small
ASSISTENTE_MAX_LENGTH_CHUNK_SIZE=1512
ASSISTENTE_CHUNK_OVERLAP=50

# -----------------------------------------------------------------------------
# CONFIGURACOES DE CONTEXTO E OUTPUT DOS MODELOS
# -----------------------------------------------------------------------------
# Estas variaveis controlam os limites de tokens para cada tipo de modelo.
# Os nomes reais dos modelos (gpt-4.1, gpt-5.1, etc.) sao configurados no proxy.

# Modelo STANDARD
ASSISTENTE_OUTPUT_TOKENS_STANDARD_MODEL=32768
ASSISTENTE_CTX_LEN_STANDARD_MODEL=250000

# Modelo MINI
ASSISTENTE_OUTPUT_TOKENS_MINI_MODEL=32000
ASSISTENTE_CTX_LEN_MINI_MODEL=250000

# Modelo NANO (opcional)
ASSISTENTE_OUTPUT_TOKENS_NANO_MODEL=30000
ASSISTENTE_CTX_LEN_NANO_MODEL=128000

# Modelo THINK (opcional - para reasoning)
ASSISTENTE_OUTPUT_TOKENS_THINK_MODEL=65000
ASSISTENTE_CTX_LEN_THINK_MODEL=128000

# -----------------------------------------------------------------------------
# DEPRECATED - Variaveis abaixo NAO sao mais utilizadas
# -----------------------------------------------------------------------------
# Apos migracao para LiteLLM Proxy, as API keys e endpoints sao gerenciados
# pelo proxy. Mantenha estas variaveis comentadas.
#
# ASSISTENTE_API_KEY_STANDARD_MODEL=
# ASSISTENTE_ENDPOINT_STANDARD_MODEL=
# ASSISTENTE_NAME_STANDARD_MODEL=
# ASSISTENTE_API_KEY_MINI_MODEL=
# ASSISTENTE_ENDPOINT_MINI_MODEL=
# ASSISTENTE_NAME_MINI_MODEL=
# ASSISTENTE_API_KEY_NANO_MODEL=
# ASSISTENTE_ENDPOINT_NANO_MODEL=
# ASSISTENTE_NAME_NANO_MODEL=
# ASSISTENTE_API_KEY_THINK_MODEL=
# ASSISTENTE_ENDPOINT_THINK_MODEL=
# ASSISTENTE_NAME_THINK_MODEL=
# ASSISTENTE_EMBEDDING_API_KEY=
# ASSISTENTE_EMBEDDING_ENDPOINT=
# ASSISTENTE_EMBEDDING_PROVIDER=

# -----------------------------------------------------------------------------
# AZURE WEB SEARCH (opcional)
# -----------------------------------------------------------------------------
PROJECT_ENDPOINT=
AZURE_WEB_AGENT_ID=
BING_CONNECTION_NAME=
MODEL_DEPLOYMENT_NAME=

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE TIMEOUT E PERFORMANCE
# -----------------------------------------------------------------------------
ASSISTENTE_TIMEOUT_API=900
ASSISTENTE_TIMEOUT_GET_DOC=120
ASSISTENTE_MAX_RETRIES=3
ASSISTENTE_REQUESTS_PER_SECOND=30.0

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE SUMARIZAÇÃO
# -----------------------------------------------------------------------------
ASSISTENTE_SUMMARIZE_MODEL=mini
ASSISTENTE_SUMMARIZE_CHUNK_SIZE=16000
ASSISTENTE_SUMMARIZE_CHUNK_MAX_OUTPUT=4000

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DA APLICAÇÃO
# -----------------------------------------------------------------------------
ASSISTENTE_PORT=8088
ASSISTENTE_DEFAULT_RESPONSE_MODEL=standard
