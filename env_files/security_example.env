# ESSENCIAIS NO MOMENTO DA INSTALACAO:
# Preferencialmente nao altere as variaveis ja setadas, pois pode haver problemas na solucao.

#### Ambiente
export GID_DOCKER=****           # O GID (Group ID) do grupo Docker no host do ambiente de instalação. Deve ser obtido executando o comando: "cat /etc/group | grep ^docker: | cut -d: -f3"
export ENVIRONMENT=prod         # Indicativo do tipo de ambiente de instalação. Para usuários externos, manter sempre como "prod". Opções disponíveis: dev, homol, prod.

#### Banco de Dados da aplicação SEI IA
export DB_SEIIA_USER=****      # Usuário de acesso ao banco de dados PostgreSQL interno do Servidor de IA.
export DB_SEIIA_PWD=****       # Senha do usuário de banco a ser criado. Não deve conter: "'" (aspas simples), """ (aspas duplas), "\", " " (espaço), "$", "(", ")", ":", "@", ";", "`" (crase), "&", "*", "+", "-", "=", "/", "?", "!", "[", "]", "{", "}", "<", ">", "|", "%", "^", "~".

# Solr da aplicação SEI IA
export SOLR_USER=seiia              # Usuário de acesso ao Solr SEI IA. Não alterar.
export SOLR_PASSWORD=****         # Senha do usuário de acesso ao Solr SEI IA.

# Airflow
export _AIRFLOW_WWW_USER_USERNAME=seiia     # Usuário para acesso à UI do Airflow. Não alterar.
export _AIRFLOW_WWW_USER_PASSWORD=****     # Senha para acesso à UI do Airflow. Não alterar.
export AIRFLOW_POSTGRES_USER=seiia          # Usuário de acesso ao PostgreSQL do Airflow. Não alterar.
export AIRFLOW_POSTGRES_PASSWORD=****      # Senha para acesso ao PostgreSQL do Airflow. Não alterar.
export AIRFLOW_AMQP_USER=seiia             # Usuário para acesso ao RabbitMQ do Airflow. Não alterar.
export AIRFLOW_AMQP_PASSWORD=****          # Senha para acesso ao RabbitMQ do Airflow. Não alterar.

## ============================================================================
## CONFIGURAÇÕES DE MODELOS LLM - LITELLM PROXY
## ============================================================================
# A partir da versão 1.2, o SEI IA usa o LiteLLM Proxy para gerenciar
# conexões com Azure OpenAI, simplificando a configuração.
# As API Keys e Endpoints dos modelos agora são configurados no arquivo
# llm_config/litellm_config.yaml

export ASSISTENTE_DEFAULT_RESPONSE_MODEL="standard"  # Modelo padrão de resposta do assistente. "standard" deve corresponder ao model_name definido em llm_config/litellm_config.yaml (não é o nome real do modelo, ex.: gpt-4.1).

# Configurações do Proxy LiteLLM (OBRIGATÓRIO)
# Configurações do container LiteLLM
export LITELLM_PORT=4000                                    # Porta do LiteLLM (interna e externa). Altere esta variável para mudar a porta do proxy.

# URL final do proxy (montada automaticamente a partir da porta acima)
export ASSISTENTE_LITELLM_PROXY_URL="http://litellm:${LITELLM_PORT}"  # URL de acesso ao proxy LiteLLM interno do Docker. Para alterar a porta, modifique LITELLM_PORT acima.
export ASSISTENTE_LITELLM_PROXY_API_KEY=""                  # API Key do proxy (vazio se sem autenticação)

# Configuração de Embeddings
export ASSISTENTE_EMBEDDING_MODEL="embedding"        # Modelo de embeddings para o RAG do Assistente. Não alterar.
export ASSISTENTE_EMBEDDING_ENCODING_NAME="o200k_base"            # Encoding tiktoken para tokenização. Não alterar se já possui base de dados.

# Limites de Tokens de Saída
export ASSISTENTE_OUTPUT_TOKENS_STANDARD_MODEL=32768    # Número máximo de tokens de saída para o modelo standard. Não alterar.
export ASSISTENTE_OUTPUT_TOKENS_MINI_MODEL=32768        # Número máximo de tokens de saída para o modelo mini. Não alterar.
export ASSISTENTE_CTX_LEN_STANDARD_MODEL=1000000    # Tamanho do contexto para o modelo standard. Não alterar.
export ASSISTENTE_CTX_LEN_MINI_MODEL=1000000    # Tamanho do contexto para o modelo mini. Não alterar.
export ASSISTENTE_OUTPUT_TOKENS_THINK_MODEL=90000       # Número máximo de tokens de saída para o modelo think. Não alterar.
export ASSISTENTE_CTX_LEN_THINK_MODEL=200000    # Tamanho do contexto para o modelo think. Não alterar.
# Configuração para resumir documentos
export ASSISTENTE_SUMMARIZE_MODEL="mini"  # Catégoria do modelo que irá resumir cada segmento. Não alterar.
export ASSISTENTE_SUMMARIZE_CHUNK_SIZE=16000  # Tamanho de entrada de cada segmento de documento a ser resumido. Não alterar.
export ASSISTENTE_SUMMARIZE_CHUNK_MAX_OUTPUT=4000  # Tamanho máximo da saída de cada segmento resumido. Não alterar.

## WsIa (API REST CENTRAL DE INTEGRAÇÃO COM OS DADOS DO SEI)
export SEI_ADDRESS=****    # Endereço raiz do SEI. Por exemplo: https://sei.orgao.gov.br
export SEI_API_DB_IDENTIFIER_SERVICE=****    # Chave de Acesso que deve ser gerada na Administração do SEI, pelo menu Administração > Sistemas > "Usuario_IA" > Serviços > "consultarDocumentoExternoIA".
export SEI_API_DB_TIMEOUT=120    # Timeout padrão da conexão da aplicação SEI IA junto à API do SEI de integração dos dados do SEI.
export SEI_API_DB_CHUNK_SIZE=100    # Quantidade de IDs enviados por requisição à API do SEI. Caso o WAF do órgão não limite o tamanho da URL, pode-se aumentar para melhorar performance (ex: 250).
export SEI_API_DB_USER=Usuario_IA    # SiglaSistema criado automaticamente pelo script de instalação do Módulo SEI IA. Não alterar.

#### AZURE WEB AGENT PARAMS
export PROJECT_ENDPOINT=****      # URL base da API do Azure AI Projects
export AZURE_TENANT_ID=****       # Tenant (Azure AD)
export AZURE_SUBSCRIPTION_ID=**** # Assinatura Azure
export AGENT_ID=****              # Agente pré-configurado no Azure AI Studio
export AZURE_WEB_AGENT_ID=****    # Agente Web/Bot
export AZURE_CLIENT_SECRET=****   # **Credencial sensível**
export AZURE_CLIENT_ID=****       # O ID do cliente (aplicativo) de um Registro de Aplicativo no Tenant
export BING_CONNECTION_NAME=****  # Nome identificador do Bing Grounding
export MODEL_DEPLOYMENT_NAME=**** # Nome identificador do modelo configurado.
