#### Configuracoes gerais para o SEI IA.
PROJECT_NAME="sei_ia"                # Define o nome do projeto.
NB_USER="seiia"                      # Define o nome do usuario para implantacao.
NB_UID=4000                          # Define o UID (User ID).
NB_GID=4000                          # Define o GID (Group ID).
VOL_SEIIA_DIR="/var/seiia/volumes"   # Define a pasta para os volumes do SEI IA.
TZ="America/Sao_Paulo"               # Timezone padrao dos containers.
COMPOSE_NETWORK_NAME="docker-host-bridge"        # Nome da rede compartilhada do compose.
LOG_LEVEL="WARNING" # Define o nível de log de todos os outros servicos (exceto deploy)para 'ERROR', que é um dos níveis possíveis: INFO | DEBUG | WARNING | ERROR.

#### Configuracoes para o Airflow do SEI IA.
AIRFLOW_UID=4000                                       # Define o UID (User ID) para o usuario do Airflow.
AIRFLOW__CORE__DEFAULT_TIMEZONE="America/Sao_Paulo"
AIRFLOW__CORE__EXECUTOR="CeleryExecutor"
AIRFLOW__CORE__PARALLELISM="32"
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG="16"
AIRFLOW__CORE__ALLOWED_DESERIALIZATION_CLASSES="airflow\\..*"
AIRFLOW__CORE__DAGBAG_IMPORT_TIMEOUT="300"
AIRFLOW__CORE__DAG_FILE_PROCESSOR_TIMEOUT="600"
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION="False"
AIRFLOW__CORE__TEST_CONNECTION="Enabled"
AIRFLOW__CORE__MIN_SERIALIZED_DAG_UPDATE_INTERVAL="120"
AIRFLOW__CORE__MIN_SERIALIZED_DAG_FETCH_INTERVAL="30"
AIRFLOW__WEBSERVER__DEFAULT_UI_TIMEZONE="America/Sao_Paulo"
AIRFLOW__WEBSERVER__EXPOSE_CONFIG="True"
AIRFLOW__WEBSERVER__WEB_SERVER_MASTER_TIMEOUT="600"
AIRFLOW__WEBSERVER__WORKERS="2"
AIRFLOW__CELERY__CELERY_APP_NAME="airflow.providers.celery.executors.celery_executor"
AIRFLOW__CELERY__SYNC_PARALLELISM="0"
AIRFLOW__CELERY__OPERATION_TIMEOUT="7200"
AIRFLOW__CELERY__TASK_TRACK_STARTED="True"
AIRFLOW__CELERY__TASK_PUBLISH_MAX_RETRIES="3"
AIRFLOW__CELERY__WORKER_PRECHECK="False"
AIRFLOW__CELERY__WORKER_TASK_LOG_READ_TIMEOUT="86400"
AIRFLOW__CELERY__BROKER_CONNECTION_TIMEOUT="300"
AIRFLOW__SCHEDULER__MAX_TIS_PER_QUERY="16"
AIRFLOW__SCHEDULER__PARSING_PROCESSES="1"
AIRFLOW__SCHEDULER__TASK_QUEUED_TIMEOUT="1200"
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK="True"
AIRFLOW__SENSORS__DEFAULT_TIMEOUT="604800"
AIRFLOW__API__AUTH_BACKENDS="airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session"
AIRFLOW__CELERY_BROKER_TRANSPORT_OPTIONS__VISIBILITY_TIMEOUT="86400"
AIRFLOW__SCHEDULER__CATCHUP_BY_DEFAULT="False"

#### Configuracoes para o Solr do SEI IA.
SOLR_HOST="infra-solr"                        # Define o nome do host interno para comunicacao com o Solr do SEI IA.
SOLR_ADDRESS="https://infra-solr:8983"        # Define o endereco da URL do Solr do SEI IA.
SOLR_MLT_JURISPRUDENCE_CORE="documentos_bm25" # Define o nome do core de documentos do Solr do SEI IA.
SOLR_MLT_PROCESS_CORE="processos_bm25"        # Define o nome do core de processos do Solr do SEI IA.


#### Configuracoes do banco de dados do SEI IA.
DB_SEIIA_HOST="infra-postgres"            # Host do BD do SEI IA.
DB_SEIIA_PORT="5432"                      # Porta do BD do SEI IA.
DB_SEIIA_SIMILARIDADE="sei_similaridade"  # Nome do banco de dados do SEI Similaridade.
DB_SEIIA_ASSISTENTE="SEI_LLM"             # Nome do banco de dados do Assistente.
DB_SEIIA_ASSISTENTE_SCHEMA="sei_llm"      # Nome do schema do banco de dados do Assistente.

#### Configuracoes do Assistente.
ASSISTENTE_MAX_RETRIES=3               # Numero de tentativas de comunicacao com a API do LLM.
ASSISTENTE_TIMEOUT_API=900             # Tempo de timeout em segundos para a comunicacao com a API do LLM.
ASSISTENTE_STREAMING_HEARTBEAT_INTERVAL=30 # Intervalo em segundos entre mensagens de heartbeat no streaming.
ASSISTENTE_MAX_LENGTH_CHUNK_SIZE="1512" # Quantidade maxima de tokens dos textos submetidos ao modelo de embeddings.
ASSISTENTE_CHUNK_OVERLAP="50"          # Quantidade de caracteres sobrepostos nos chunks.
ASSISTENTE_DEFAULT_RESPONSE_MODEL="standard" # Modelo padrao de resposta do assistente.
EMBEDDING_MODEL="embedding"            # Alias compartilhado do modelo de embeddings configurado no LiteLLM.
ASSISTENTE_EMBEDDING_ENCODING_NAME="o200k_base" # Encoding usado para tokenizacao dos embeddings.
ASSISTENTE_OUTPUT_TOKENS_STANDARD_MODEL=32768 # Limite de tokens de saida do modelo standard.
ASSISTENTE_OUTPUT_TOKENS_MINI_MODEL=32768 # Limite de tokens de saida do modelo mini.
ASSISTENTE_CTX_LEN_STANDARD_MODEL=1000000 # Tamanho de contexto do modelo standard.
ASSISTENTE_CTX_LEN_MINI_MODEL=1000000    # Tamanho de contexto do modelo mini.
ASSISTENTE_OUTPUT_TOKENS_THINK_MODEL=90000 # Limite de tokens de saida do modelo think.
ASSISTENTE_CTX_LEN_THINK_MODEL=400000    # Tamanho de contexto do modelo think.
ASSISTENTE_SUMMARIZE_MODEL="mini"        # Categoria de modelo usada para sumarizacao.
ASSISTENTE_SUMMARIZE_CHUNK_SIZE=16000    # Tamanho de entrada de cada segmento a resumir.
ASSISTENTE_SUMMARIZE_CHUNK_MAX_OUTPUT=4000 # Tamanho maximo da saida de cada resumo.
ASSISTENTE_LITELLM_PROXY_URL="http://infra-litellm:4000" # URL interna do proxy LiteLLM.
ASSISTENTE_PORT=8088                    # Porta externa padrao publicada para o Assistente.

# Configuracoes para deploy externo.
# Mudancas neste arquivo versionado devem passar pelo fluxo de deploy do GitLab, atualizar a stack e validar o runtime.
ASSISTENTE_USE_LANGFUSE=false          # Define se o Langfuse esta ativo no Assistente do SEI IA.

#### Integracao com a API do SEI.
SEI_API_DB_TIMEOUT=120                 # Timeout padrao das requisicoes para a API do SEI.
SEI_API_DB_USER="Usuario_IA"           # Usuario/sigla de sistema usado na API do SEI.

### Airflow stack ###
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=16 # Define o número máximo de execuções ativas por DAG como 16; padrão do Airflow 2.9
AIRFLOW__CELERY__WORKER_CONCURRENCY=8     # Define a concorrência dos workers do Celery do Airflow.
AIRFLOW_WORKERS_REPLICAS=3           # Define o número de replicas de workers do Airflow.
AIRFLOW_WORKER_MEM_LIMIT=20g         # Define o limite de memória para cada worker do Airflow.
AIRFLOW_WORKER_CPU_LIMIT='3'         # Define o limite de CPU para cada worker do Airflow.
AIRFLOW_POSTGRES_MEM_LIMIT=6g        # Define o limite de memória para o Postgres do Airflow.
AIRFLOW_POSTGRES_CPU_LIMIT='4'       # Define o limite de CPU para o Postgres do Airflow.
RABBITMQ_MEM_LIMIT=2g                # Define o limite de memória para RabbitMQ.
RABBITMQ_CPU_LIMIT='1'               # Define o limite de CPU para RabbitMQ.
AIRFLOW_WEBSERVER_MEM_LIMIT=2g       # Define o limite de memória para o servidor web do Airflow.
AIRFLOW_WEBSERVER_CPU_LIMIT='2'      # Define o limite de CPU para o servidor web do Airflow.
AIRFLOW_SCHEDULER_MEM_LIMIT=4g       # Define o limite de memória para o agendador do Airflow.
AIRFLOW_SCHEDULER_CPU_LIMIT='2'      # Define o limite de CPU para o agendador do Airflow.
AIRFLOW_SCHEDULER_CPU_SHARES='2048'  # Define a quantidade de 'shares' de CPU para o agendador do Airflow.
AIRFLOW_TRIGGERER_MEM_LIMIT=1g       # Define o limite de memória para o triggerer do Airflow.
AIRFLOW_TRIGGERER_CPU_LIMIT='2'      # Define o limite de CPU para o triggerer do Airflow.

### Api sei ###
API_SEI_MEM_LIMIT=4g                    # Define o limite de memória para a API do SEI.
API_SEI_CPU_LIMIT='0.5'                 # Define o limite de CPU para a API do SEI.

### App api ###
APP_API_MEM_LIMIT=512mb  # Define o limite de memória para a API do aplicativo.
APP_API_CPU_LIMIT='0.3'  # Define o limite de CPU para a API do aplicativo.

### Solr ###
SOLR_JAVA_MEM='-Xms2g -Xmx6g' # Define as opções de memória Java para Solr no ambiente local.
SOLR_MEM_LIMIT=8g              # Define o limite de memória para Solr.
SOLR_CPU_LIMIT='8'             # Define o limite de CPU para Solr.

### Pgvector ###
PGVECTOR_MEM_LIMIT=16g   # Define o limite de memória para o BD.
PGVECTOR_CPU_LIMIT='4'  # Define o limite de CPU para o BD.

### Assistente ###
ASSISTENTE_MEM_LIMIT=6gb             # Define o limite de memória.
ASSISTENTE_CPU_LIMIT='4'             # Define o limite de CPU para o Assistente.
ASSISTENTE_NGINX_MEM_LIMIT=4gb       # Define o limite de memória para o Nginx do Assistente.
ASSISTENTE_NGINX_CPU_LIMIT='6'       # Define o limite de CPU para o Nginx do Assistente.
ASSISTENTE_CONTEXT_MAX_TOKENS=128000 # Define o tamanho máximo do contexto para o LLM do Assistente.
ASSISTENTE_FATOR_LIMITAR_RAG="4"     # Defini o limite para o RAG em relação ao contexto do modelo, [valor] * ASSISTENTE_CONTEXT_MAX_TOKENS
ASSISTENTE_OCR_MAX_CONCURRENT_PAGES=15 # Numero maximo de paginas OCR processadas em paralelo


### Geracao de embeddings
EMBEDDING_MAX_ACTIVE_RUNS="10"

### Limites de recursos para o LiteLLM Proxy
LITELLM_CPU_LIMIT='2'
LITELLM_MEM_LIMIT=8g
LITELLM_LOG_LEVEL="WARNING"  # DEBUG | INFO | WARNING | ERROR
